{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
      "allow": [
        "Bash(uv sync)",
        "Bash(uv run pytest *)",
        "Bash(uv run ruff check *)",
        "Bash(uv run ruff format *)",
        "Bash(uv run mypy *)",
        "Bash(git status)",
        "Bash(git diff *)",
        "Bash(git log *)",
        "Bash(* --version)",
        "Bash(* --help *)"
      ],
      "deny": [
        "Read(./.env)",
        "Read(./secrets/**)",
        "Read(./config/credentials.json)",
        "Bash(git push *)"
      ]
    },
    "model": "opusplan"
  }