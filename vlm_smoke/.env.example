# Frame source: camera | rtmp | webcam | video
FRAME_SOURCE_TYPE=camera

# --- camera (FRAME_SOURCE_TYPE=camera) — same presets as camera_test ---
# tapo-rtsp | tapo-webrtc | phone-webrtc
CAMERA_SOURCE=tapo-rtsp
RTSP_URL=rtsp://camera_user:camera_pass@192.168.1.50:554/stream2
# WEBRTC_URL=http://localhost:8889/tapo/whep
# PHONE_STREAM_URL=rtsp://127.0.0.1:8554/phone
RTSP_TRANSPORT=tcp
RTSP_LOW_LATENCY=true
RTSP_FLUSH_GRABS=8

# --- legacy sources ---
# RTMP (GoPro relay)
RTMP_URL=rtmp://localhost:1935/live/gopro
WEBCAM_INDEX=0
VIDEO_PATH=

# VLM settings: openai | ollama (local, no API key)
VLM_PROVIDER=openai
VLM_MODEL=gpt-5.5
OPENAI_API_KEY=your-key-here

# Local Ollama (when VLM_PROVIDER=ollama) — vision model required:
#   ollama pull llava
# VLM_PROVIDER=ollama
# VLM_MODEL=llava
# OLLAMA_BASE_URL=http://localhost:11434

FRAME_SAMPLE_DIR=outputs/sampled_frames
NUM_FRAMES_PER_QUERY=1
SAVE_QUERIED_FRAMES=true
FRAME_BUFFER_SIZE=8
RTMP_SAMPLE_INTERVAL_SEC=1.0
