# Frame source: rtmp | webcam | video
FRAME_SOURCE_TYPE=rtmp

# RTMP (GoPro relay)
RTMP_URL=rtmp://localhost:1935/live/gopro

# Webcam device index
WEBCAM_INDEX=0

# Local video file (required when FRAME_SOURCE_TYPE=video)
VIDEO_PATH=

# VLM settings
VLM_PROVIDER=openai
VLM_MODEL=gpt-5.5
OPENAI_API_KEY=your-key-here

# Frame sampling and saving
FRAME_SAMPLE_DIR=outputs/sampled_frames
NUM_FRAMES_PER_QUERY=1
SAVE_QUERIED_FRAMES=true

# Capture buffer (ring buffer size for recent frames)
FRAME_BUFFER_SIZE=8

# How often to sample frames into the buffer (seconds)
RTMP_SAMPLE_INTERVAL_SEC=1.0
