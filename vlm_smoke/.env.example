# Frame source: camera | webcam | video
FRAME_SOURCE_TYPE=camera

# --- camera (FRAME_SOURCE_TYPE=camera) — see README "Camera sources" ---
#
# Tapo RTSP direct (recommended, lowest latency):
# CAMERA_SOURCE=tapo-rtsp
# RTSP_URL=rtsp://camera_user:camera_pass@192.168.1.50:554/stream2
#
# Tapo via MediaMTX (start: cd camera_test && mediamtx mediamtx-tapo.yml):
# CAMERA_SOURCE=tapo-webrtc
# WEBRTC_URL=http://localhost:8889/tapo/whep
#
# iPhone via MediaMTX (start: mediamtx mediamtx-phone.yml, phone publishes HTTPS):
# CAMERA_SOURCE=phone-webrtc
# PHONE_STREAM_URL=rtsp://127.0.0.1:8554/phone

CAMERA_SOURCE=tapo-rtsp
RTSP_URL=rtsp://camera_user:camera_pass@192.168.1.50:554/stream2
RTSP_TRANSPORT=tcp
RTSP_LOW_LATENCY=true
RTSP_FLUSH_GRABS=8
# RTSP_FFMPEG_LOG=rtsp_decode.log   # FFmpeg + app logs; terminal = REPL only
# RTSP_FFMPEG_LOG=off               # print logs on terminal instead

# --- optional sources ---
WEBCAM_INDEX=0
VIDEO_PATH=

# VLM: openai | ollama
VLM_PROVIDER=openai
VLM_MODEL=gpt-5.5
OPENAI_API_KEY=your-key-here
# VLM_PROVIDER=ollama
# VLM_MODEL=llava
# OLLAMA_BASE_URL=http://localhost:11434

FRAME_SAMPLE_DIR=outputs/sampled_frames
NUM_FRAMES_PER_QUERY=1
SAVE_QUERIED_FRAMES=true
FRAME_BUFFER_SIZE=8
CAPTURE_SAMPLE_INTERVAL_SEC=1.0
