# Frame source: rtmp | webcam | video
FRAME_SOURCE_TYPE=rtmp

# RTMP (GoPro relay)
RTMP_URL=rtmp://localhost:1935/live/gopro

# Webcam device index
WEBCAM_INDEX=0

# Local video file (required when FRAME_SOURCE_TYPE=video)
VIDEO_PATH=

# VLM settings: openai | ollama (local, no API key)
VLM_PROVIDER=openai # openai or ollama
VLM_MODEL=gpt-5.5
OPENAI_API_KEY=your-key-here

# Local Ollama (when VLM_PROVIDER=ollama)
# Example models: llava, qwen2.5vl:7b, llama3.2-vision
# OLLAMA_BASE_URL=http://localhost:11434

# Background capture buffer (not memory write interval)
FRAME_BUFFER_SIZE=8
CAPTURE_SAMPLE_INTERVAL_SEC=1.0
NUM_FRAMES_PER_QUERY=1

# Output paths (relative to memory_log project root)
OUTPUT_FRAME_DIR=outputs/frames
MEMORY_JSONL_PATH=outputs/memories.jsonl

# Optional location label (no GPS in this phase)
LOCATION_LABEL=

# Save frame image when a memory is written
SAVE_FRAMES=true

# Optional max runtime in seconds (unset = run until Ctrl+C)
MAX_RUNTIME_SECONDS=
