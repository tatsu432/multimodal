# Frame source: camera | rtmp | webcam | video
FRAME_SOURCE_TYPE=camera

# --- camera (FRAME_SOURCE_TYPE=camera) — same presets as camera_test ---
CAMERA_SOURCE=phone-webrtc
# RTSP_URL=rtsp://camera_user:camera_pass@192.168.1.50:554/stream2
PHONE_STREAM_URL=rtsp://127.0.0.1:8554/phone
RTSP_TRANSPORT=tcp
RTSP_LOW_LATENCY=true
RTSP_FLUSH_GRABS=8

# --- legacy sources ---
RTMP_URL=rtmp://localhost:1935/live/gopro
WEBCAM_INDEX=0
VIDEO_PATH=

# VLM settings: openai | ollama
VLM_PROVIDER=openai
VLM_MODEL=gpt-5.5
OPENAI_API_KEY=your-key-here
# VLM_PROVIDER=ollama
# VLM_MODEL=llava
# OLLAMA_BASE_URL=http://localhost:11434

FRAME_BUFFER_SIZE=8
CAPTURE_SAMPLE_INTERVAL_SEC=1.0
NUM_FRAMES_PER_QUERY=1
OUTPUT_FRAME_DIR=outputs/frames
MEMORY_JSONL_PATH=outputs/memories.jsonl
LOCATION_LABEL=
SAVE_FRAMES=true
MAX_RUNTIME_SECONDS=
