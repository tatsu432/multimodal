# Frame source: camera | webcam | video
FRAME_SOURCE_TYPE=camera

# --- camera — see README "Camera sources" and vlm_smoke/README.md ---
# Tapo RTSP: CAMERA_SOURCE=tapo-rtsp + RTSP_URL
# Tapo + MediaMTX: CAMERA_SOURCE=tapo-webrtc + mediamtx-tapo.yml
# Phone + MediaMTX: CAMERA_SOURCE=phone-webrtc + PHONE_STREAM_URL + mediamtx-phone.yml

CAMERA_SOURCE=tapo-rtsp
RTSP_URL=rtsp://camera_user:camera_pass@192.168.1.50:554/stream2
RTSP_TRANSPORT=tcp
RTSP_LOW_LATENCY=true
RTSP_FLUSH_GRABS=8

# --- optional sources ---
WEBCAM_INDEX=0
VIDEO_PATH=

# VLM: openai | ollama (vision model required for ollama, e.g. llava)
VLM_PROVIDER=openai
VLM_MODEL=gpt-5.5
OPENAI_API_KEY=your-key-here
# VLM_PROVIDER=ollama
# VLM_MODEL=llava
# OLLAMA_BASE_URL=http://localhost:11434

FRAME_BUFFER_SIZE=8
CAPTURE_SAMPLE_INTERVAL_SEC=1.0
NUM_FRAMES_PER_QUERY=1
OUTPUT_FRAME_DIR=outputs/frames
MEMORY_JSONL_PATH=outputs/memories.jsonl
SAVE_FRAMES=true
MAX_RUNTIME_SECONDS=

# --- location (no VLM; config-based) ---
# Global fallback for any source:
LOCATION_LABEL=default location
LOCATION_LAT=35.681236
LOCATION_LON=139.767125
# Fixed Tapo camera location (overrides global when CAMERA_SOURCE is tapo-*):
TAPO_LOCATION_LABEL=tapo location
TAPO_LOCATION_LAT=35.681236
TAPO_LOCATION_LON=139.767125
# Phone fallback when GPS sidecar is off or stale:
PHONE_LOCATION_LABEL=phone location 
PHONE_LOCATION_LAT=35.681236
PHONE_LOCATION_LON=139.767125

# --- phone GPS sidecar (optional; requires HTTPS certs on phone) ---
LOCATION_SERVER_ENABLED=true
LOCATION_SERVER_HOST=192.168.11.51
LOCATION_SERVER_PORT=8765
# Reuse mkcert certs from camera_test, e.g.:
# LOCATION_SERVER_CERT=../camera_test/mediamtx-certs/server.crt
# LOCATION_SERVER_KEY=../camera_test/mediamtx-certs/server.key
LOCATION_SERVER_CERT=../camera_test/mediamtx-certs/server.crt
LOCATION_SERVER_KEY=../camera_test/mediamtx-certs/server.key
LOCATION_GPS_MAX_AGE_SEC=120

# --- reverse geocoding (lat/lon → address at write time; SQLite cache) ---
GEOCODE_ENABLED=true
GEOCODE_PROVIDER=nominatim
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
GEOCODE_CACHE_PATH=outputs/geocode_cache.sqlite
GEOCODE_TIMEOUT_SEC=5
# Skip Nominatim only when a manual label and full_address are already set
GEOCODE_SKIP_IF_LABEL_SET=false

# --- SQLite memory database ---
MEMORY_DB_PATH=outputs/memory.sqlite

# --- Passive observer ---
# How often to write a passive observation row (seconds)
PASSIVE_OBSERVATION_INTERVAL_SEC=30
# Save a frame image + thumbnail for each passive observation
PASSIVE_SAVE_FRAMES=true
PASSIVE_FRAME_DIR=outputs/passive_frames
# Directory for frames saved when a promoted event is created from active queries
PROMOTED_EVENT_FRAME_DIR=outputs/event_frames

# --- Long-term memory query retrieval budgets ---
LTM_MAX_PASSIVE_ROWS=1000
LTM_PROMOTED_EVENT_TOP_K=20
LTM_ACTIVE_QUERY_TOP_K=10
LTM_FINAL_EVENT_K=5
# Enable visual grounding for "this/here" queries (requires live camera)
LTM_USE_VISUAL_GROUNDING=true

# --- Long-term query logging (separate DB; excluded from memory retrieval) ---
# Set to false to disable telemetry logging entirely
LTM_QUERY_LOG_ENABLED=true
QUERY_LOG_DB_PATH=outputs/long_term_query_logs.sqlite

# --- Vector / semantic search (ChromaDB + embedding provider) ---
# Set to false to disable vector search and fall back to SQLite LIKE keyword matching
VECTOR_SEARCH_ENABLED=true
# Embedding provider: ollama (default, no API key) or openai
EMBEDDING_PROVIDER=ollama
# Model name (default per provider: ollama→nomic-embed-text, openai→text-embedding-3-small)
# EMBEDDING_MODEL=nomic-embed-text
# Also embed new memories at write time (true recommended; false = query only)
EMBED_ON_WRITE=true
# Path to ChromaDB persistence directory (model-namespaced collections inside)
CHROMA_PATH=outputs/chroma
# Timeout for embedding HTTP calls (seconds)
EMBEDDING_TIMEOUT_SEC=30
# OpenAI example (requires OPENAI_API_KEY above):
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
