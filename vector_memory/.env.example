# Path to Step 2 memory records (relative to vector_memory project root)
MEMORY_JSONL_PATH=../memory_log/outputs/memories.jsonl

# Chroma persistent storage (relative to vector_memory project root)
CHROMA_PERSIST_DIR=outputs/chroma
CHROMA_COLLECTION_NAME=visual_memories

# Embeddings: sentence_transformers (default, local) or openai
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Max results per query
DEFAULT_LIMIT=10

# Only index/search records where should_store=true
DEFAULT_SHOULD_STORE_ONLY=true

# Timezone for "today", "yesterday", "recently", etc.
TIMEZONE=Asia/Tokyo

# Optional LLM summarization (default off — template answerer only)
USE_LLM_ANSWERER=false
LLM_MODEL=

# Set true once to clear and rebuild the Chroma collection; then set back to false
REBUILD_INDEX=false
