# Camera setup: tapo-rtsp | tapo-webrtc | phone-webrtc
CAMERA_SOURCE=tapo-rtsp

# Tapo RTSP (CAMERA_SOURCE=tapo-rtsp)
RTSP_URL=rtsp://camera_user:camera_pass@camera_ip:554/stream2

# RTSP transport for OpenCV/FFmpeg: tcp (Tapo default) or udp
# For local MediaMTX phone relay (127.0.0.1:8554), udp is usually lower latency.
RTSP_TRANSPORT=tcp

# Low-latency RTSP (auto-enabled for 127.0.0.1 / localhost URLs):
# RTSP_LOW_LATENCY=true
# RTSP_FLUSH_GRABS=8   # drop buffered frames each read (fixes "frozen" preview)
# RTSP_STALE_SEC=3     # reconnect if pixels unchanged this long
# RTSP_FFMPEG_LOG=rtsp_decode.log   # FFmpeg warnings → file (default). Only one line — do not duplicate.
# RTSP_FFMPEG_LOG=off               # print FFmpeg warnings on terminal instead

# WebRTC via WHEP — path must match mediamtx.yml
#
# Tapo (RTSP pull → MediaMTX → WHEP):
# CAMERA_SOURCE=tapo-webrtc
# WEBRTC_URL=http://localhost:8889/tapo/whep
#
# Smartphone (phone publishes WebRTC → MediaMTX; Python reads RTSP relay):
PHONE_STREAM_URL=rtsp://127.0.0.1:8554/phone
#
# Optional WHEP (experimental with webrtcEncryption + aiortc):
# PHONE_STREAM_URL=https://localhost:8889/phone/whep

# Optional STUN/TURN servers (comma-separated) for WebRTC NAT traversal
# WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302

# HTTPS WHEP (phone-webrtc): Python auto-trusts mkcert if installed; override with:
# WEBRTC_CA_FILE=/path/to/rootCA.pem
# WEBRTC_SSL_VERIFY=false   # dev only — skip TLS verification

# Seconds to wait for WHEP connect + first frame
WEBRTC_OPEN_TIMEOUT_SEC=30

# Python preview for tapo-webrtc: RTSP relay from MediaMTX (fast) vs WHEP capture (slow).
# Default true — reads rtsp://127.0.0.1:8554/<path> while browser uses WebRTC.
# WEBRTC_PREVIEW_VIA_RTSP=true
# MEDIAMTX_RTSP_BASE=rtsp://127.0.0.1:8554

# WHEP capture (only when WEBRTC_PREVIEW_VIA_RTSP=false):
# subprocess = aiortc worker (Linux); browser = Chromium player (macOS fallback)
# WEBRTC_IPC=browser
# BROWSER_CAPTURE_SCALE=0.667
# BROWSER_JPEG_QUALITY=0.65
WEBRTC_IPC=subprocess

# VLM settings (camera-vlm only): openai | ollama
VLM_PROVIDER=openai
VLM_MODEL=gpt-5.5
OPENAI_API_KEY=your-key-here

# Local Ollama (when VLM_PROVIDER=ollama) — needs a vision model, not text-only qwen3/deepseek:
#   ollama pull llava
#   ollama list
# VLM_PROVIDER=ollama
# VLM_MODEL=llava
# OLLAMA_BASE_URL=http://localhost:11434
