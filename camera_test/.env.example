# Frame source: rtmp | rtsp | webrtc | webcam | video
FRAME_SOURCE_TYPE=rtmp

# RTMP (GoPro relay)
RTMP_URL=rtmp://localhost:1935/live/gopro

# RTSP (e.g. Tapo IP camera) — use with FRAME_SOURCE_TYPE=rtsp
RTSP_URL=rtsp://camera_user:camera_pass@192.168.1.50:554/stream2

# RTSP transport for OpenCV/FFmpeg: tcp (Tapo default) or udp
RTSP_TRANSPORT=tcp

# WebRTC via WHEP — path must match mediamtx.yml (Tapo example uses tapo, not live)
WEBRTC_URL=http://localhost:8889/tapo/whep

# Optional STUN/TURN servers (comma-separated) for WebRTC NAT traversal
# WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302

# Seconds to wait for the first WebRTC video frame
# WEBRTC_OPEN_TIMEOUT_SEC=15

# Webcam device index (when FRAME_SOURCE_TYPE=webcam)
WEBCAM_INDEX=0

# Local video file (required when FRAME_SOURCE_TYPE=video)
VIDEO_PATH=

# VLM settings (live_vlm_qa only): openai | ollama
VLM_PROVIDER=openai
VLM_MODEL=gpt-5.5
OPENAI_API_KEY=your-key-here

# Local Ollama (when VLM_PROVIDER=ollama)
# Example models: llava, qwen2.5vl:7b, llama3.2-vision
# OLLAMA_BASE_URL=http://localhost:11434
