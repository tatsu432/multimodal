# Path to Step 2 memory records (relative to memory_search project root)
MEMORY_JSONL_PATH=../memory_log/outputs/memories.jsonl

# Max results per query
DEFAULT_LIMIT=10

# Only search records where should_store=true
DEFAULT_SHOULD_STORE_ONLY=true

# Timezone for "today", "yesterday", "recently", etc.
TIMEZONE=Asia/Tokyo

# Optional LLM summarization (default off — template answerer only)
USE_LLM_ANSWERER=false
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.5
OPENAI_API_KEY=

# Local Ollama (when LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434
